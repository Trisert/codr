# ============================================================
# Model Provider Configuration
# ============================================================

# Choose which model to use: "anthropic", "llama", or "nim"
# Default: llama
MODEL_TYPE=llama

# ============================================================
# Anthropic Claude API
# ============================================================

# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# ============================================================
# llama-server (llama.cpp) Configuration
# ============================================================

# Base URL for llama-server
# Default: http://localhost:8080
LLAMA_SERVER_URL=http://localhost:8080

# Model name to use
# Default: default
LLAMA_MODEL=default

# ============================================================
# NVIDIA NIM Configuration
# ============================================================

# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key-here

# Base URL for NIM endpoint
# Default: https://integrate.api.nvidia.com
NIM_BASE_URL=https://integrate.api.nvidia.com

# Model to use
# Default: meta/llama-3.1-70b-instruct
NIM_MODEL=meta/llama-3.1-70b-instruct
